@model List<Logica_de_Negocio.ViewModels.ProductoraViewModel>

@{
    ViewData["Title"] = "Mantenimiento de Productoras";
}

<div class="container">
    <h1 class="text-center text-white">Mantenimiento de Productoras</h1>

    <div class="mb-4">
        <a asp-action="CrearProductora" class="btn btn-success">Crear Nueva Productora</a>
    </div>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Descripcion</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var productora in Model)
            {
                <tr>
                    <td>@productora.name</td>
                    <td>@productora.description</td>
                    <td>
                        <a asp-action="EditarProductora" asp-route-id="@productora.IdProductora" class="btn btn-primary">Editar</a>
                        <a asp-action="EliminarProductora" asp-route-id="@productora.IdProductora" class="btn btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>