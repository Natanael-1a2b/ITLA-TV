@model Logica_de_Negocio.ViewModels.ProductoraViewModel

@{
    ViewData["Title"] = "Editar Productora";
}

<div class="container">
    <div class="card bg-dark p-2">
        <h1 class="text-white card-header">Editar Productora</h1>

        <form asp-action="EditarProductora">
            <input type="hidden" asp-for="IdProductora" />

            <div class="form-group text-white m-3">
            <label asp-for="name">Nombre</label>
            <input asp-for="name" class="form-control bg-secondary text-white" />
            <span asp-validation-for="name" class="text-danger"></span>
            </div>
            <div class="form-group text-white m-3">
                <label asp-for="description">Descripción (Opcional)</label>
                <textarea asp-for="description" class="form-control bg-secondary text-white" rows="3"></textarea>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-outline-success m-3">Guardar</button>
                <a asp-action="MantenimientoDeProductoras" class="btn btn-outline-danger m-3">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}