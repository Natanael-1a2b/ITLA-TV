@model Logica_de_Negocio.ViewModels.ProductoraViewModel

@{
    ViewData["Title"] = "Crear Productora";
}

<div class="container">
    <div class="card bg-dark p-2">
        <h1 class="text-white card-header">Crear Productora</h1>

        <form asp-action="CrearProductora">
            <div class="form-group m-3 text-white">
                <label asp-for="name">Nombre</label>
                <input asp-for="name" class="form-control bg-secondary text-white" />
                <span asp-validation-for="name" class="text-danger"></span>
            </div>
            <div class="form-group m-3 text-white">
                <label asp-for="description">Descripción (Opcional)</label>
                <textarea asp-for="description" class="form-control bg-secondary text-white" rows="3"></textarea>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-outline-success m-3">Crear</button>
                <a asp-action="MantenimientoDeProductoras" class="btn btn-outline-danger m-3">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}