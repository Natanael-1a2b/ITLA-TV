@model Logica_de_Negocio.ViewModels.GeneroViewModel

@{
    ViewData["Title"] = "Editar Género";
}

<div class="container">
    <div class="card bg-dark p-4">
        <h1 class="text-white card-header">Editar Género</h1>

        <form asp-action="EditarGenero">
            <input type="hidden" asp-for="IdGenero" />

            <div class="form-group p-2 text-white">
                <label asp-for="name">Nombre</label>
                <input asp-for="name" class="form-control bg-secondary text-white" />
                <span asp-validation-for="name" class="text-danger"></span>
            </div>

            <div class="form-group p-2 text-white">
                <label asp-for="description">Descripción (Opcional)</label>
                <textarea asp-for="description" class="form-control bg-secondary text-white" rows="3"></textarea>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-outline-success p-2">Guardar</button>
                <a asp-action="MantenimientoDeGeneros" class="btn btn-outline-danger">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}